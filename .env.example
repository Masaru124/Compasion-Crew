# Sanity Project Credentials
NEXT_PUBLIC_SANITY_PROJECT_ID="your_project_id"
NEXT_PUBLIC_SANITY_DATASET="production"

# Sanity API Write Token (needed for seeding / migration script)
# Create a token with "Editor" or "Administrator" permissions under sanity.io/manage
SANITY_API_WRITE_TOKEN="your_write_token"

# Auth.js / NextAuth Session Encryption Secret
# Generate with: npx auth secret
AUTH_SECRET="generate_a_random_secret_here"

# Admin Credentials
# Email used as the admin username for login
ADMIN_EMAIL="admin@compassioncrew.in"
# Bcrypt hash of the admin password
# Generate with: node scripts/hash-password.js "YourStrongPassword"
ADMIN_PASSWORD_HASH="paste_bcrypt_hash_here"

# Neon PostgreSQL Database URL
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
